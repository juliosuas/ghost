# Ghost OSINT Platform Configuration
# Copy this file to .env and fill in your API keys

# === REQUIRED ===
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# === OPTIONAL — Enhance capabilities ===

# Have I Been Pwned (breach checks)
HIBP_API_KEY=

# Shodan (network intelligence)
SHODAN_API_KEY=

# Google Custom Search (reverse image search, web search)
GOOGLE_API_KEY=
GOOGLE_CX=

# Twitter/X API
TWITTER_BEARER_TOKEN=

# IP Geolocation
IPINFO_TOKEN=

# Hunter.io (email discovery)
HUNTER_API_KEY=

# FullContact (identity resolution)
FULLCONTACT_API_KEY=

# === SERVER CONFIG ===
GHOST_HOST=0.0.0.0
GHOST_PORT=5000
GHOST_DEBUG=false
GHOST_SECRET_KEY=change-this-to-a-random-string

# === DATABASE ===
DATABASE_URL=sqlite:///ghost.db

# === RATE LIMITING ===
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60
